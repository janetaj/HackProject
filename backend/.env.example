# Environment Configuration Template
# Copy this file to .env and fill in actual values for your environment

# ==============================================================================
# APPLICATION
# ==============================================================================
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:3001

# ==============================================================================
# DATABASE - PostgreSQL (Local or Supabase)
# ==============================================================================
# LOCAL DEVELOPMENT:
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=testgen_app
# DB_PASSWORD=your_secure_password_here
# DB_NAME=testgen
# DB_POOL_MIN=2
# DB_POOL_MAX=20
# DB_SSL=false

# SUPABASE PRODUCTION (Recommended):
DB_HOST=db.YOUR_PROJECT_ID.supabase.co
DB_PORT=5432
DB_USER=postgres.YOUR_PROJECT_ID
DB_PASSWORD=your_database_password_here
DB_NAME=postgres
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false

# ==============================================================================
# REDIS
# ==============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
BULLMQ_CONCURRENCY=1

# ==============================================================================
# JWT (Authentication)
# ==============================================================================
# Generate a secure secret: openssl rand -base64 32
JWT_SECRET=your_256_character_secret_key_min_32_chars_required_here_change_this
JWT_REFRESH_SECRET=your_256_character_refresh_secret_key_min_32_chars_required_here_change_this
JWT_ACCESS_EXPIRY=900
JWT_REFRESH_EXPIRY=604800
JWT_ALGORITHM=HS256

# ==============================================================================
# JIRA
# ==============================================================================
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_API_VERSION=3
JIRA_POLL_INTERVAL_MS=120000
JIRA_TIMEOUT_MS=30000
JIRA_MAX_RETRIES=3
JIRA_RATE_LIMIT_PER_MINUTE=60
JIRA_JQL_MAX_RESULTS=100

# ==============================================================================
# LLM PROVIDERS
# ==============================================================================

# OpenAI (GPT-4o for generation and chatbot)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
OPENAI_GENERATION_MODEL=gpt-4o
OPENAI_CHATBOT_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.3
OPENAI_TIMEOUT_MS=60000

# Groq (Llama/Mixtral for parsing and fallback)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_PARSING_MODEL=llama-3.1-70b
GROQ_FALLBACK_MODEL=mixtral-8x7b
GROQ_MAX_TOKENS=1024
GROQ_TEMPERATURE=0.1
GROQ_TIMEOUT_MS=15000

# General LLM Settings
LLM_PRIMARY_PROVIDER=openai
LLM_FALLBACK_PROVIDER=groq
LLM_CACHE_GENERATION=true
LLM_CACHE_PARSING=true
LLM_CACHE_TTL_HOURS=24

# ==============================================================================
# BUDGET & COST CONTROL
# ==============================================================================
MONTHLY_BUDGET_EURO=25
BUDGET_ALLOCATION=generation:40,parsing:20,chatbot:40
BUDGET_PER_USER_DAILY_LIMIT=qa_tester:1.0,qa_lead:2.0,admin:5.0
BUDGET_ALERT_THRESHOLDS=50,80,95
BUDGET_EXHAUSTION_BEHAVIOR=fallback_to_groq
BUDGET_TRACKING_ENABLED=true
BUDGET_WARNING_THRESHOLD_EURO=1.0

# ==============================================================================
# ENCRYPTION
# ==============================================================================
# Generate a secure key: openssl rand -base64 32
AES_ENCRYPTION_KEY=your_aes_256_encryption_key_base64_encoded_32_chars_required_here

# ==============================================================================
# OBSERVABILITY
# ==============================================================================
LOG_LEVEL=info
OTEL_EXPORTER_TYPE=console
OTEL_SERVICE_NAME=testgen-backend
OTEL_COLLECTOR_URL=http://localhost:4317

# ==============================================================================
# FEATURE FLAGS
# ==============================================================================
FEATURE_WEBHOOK_INTEGRATION=false
FEATURE_MCP_INTEGRATION=true
FEATURE_RAG_ENABLED=false
